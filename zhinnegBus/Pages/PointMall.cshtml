@page "/PointMall"
@model zhinnegBus.Pages.PointMallModel
@Html.AntiForgeryToken()
<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background-color: #e6f8ee;
        font-family: "微软雅黑", sans-serif;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
    }

    .title {
        font-size: 32px;
        font-weight: bold;
    }

    .top-btn-group button {
        border: 0;
        background: #60c697;
        color: white;
        padding: 8px 14px;
        border-radius: 6px;
        margin-left: 8px;
        cursor: pointer;
    }

    .search-wrap {
        padding: 0 20px 20px;
    }

    #searchInput {
        width: 100%;
        padding: 12px 16px;
        border-radius: 99px;
        border: 1px solid #ccc;
        font-size: 16px;
    }

    .goods-wrap {
        padding: 0 20px;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 24px;
    }

    .coupon-card {
        background: #fff;
        border-radius: 8px;
        overflow: visible;
        height: auto;
        display: flex;
        flex-direction: column;
    }

        .coupon-card img {
            width: 100%;
            height: 240px;
            object-fit: cover;
        }

    .info {
        flex: 1;
        padding: 10px;
    }

        .info h4 {
            font-size: 22px;
            margin-bottom: 10px;
        }

        .info span, .info p {
            font-size: 16px;
            margin: 6px 0;
            color: #333;
        }

    .free-tag {
        color: red;
        font-weight: bold;
    }

    .exchange-btn {
        width: 100%;
        border: 0;
        background: #60c697;
        color: white;
        padding: 12px;
        font-size: 16px;
        cursor: pointer;
    }

    .footer {
        margin-top: 60px;
        padding: 30px 20px;
        text-align: center;
        color: #666;
    }
</style>
<div class="top-bar">
    <div class="title">积分商城</div>
    <div class="top-btn-group">
        <span>当前积分：@Model.UserPoint</span>
        <button onclick="location.href='/SkinShop'">皮肤商城</button>
        <button onclick="location.href='/MyCoupon'">我的优惠券</button>
    </div>
</div>
<div class="search-wrap">
    <input id="searchInput" placeholder="搜索优惠券名称">
</div>
<div class="goods-wrap">
    @foreach (var item in Model.CouponList)
    {
        string showValid = $"有效期{item.ValidDay}天";
        string showDiscount = $"抵扣{item.DiscountMoney}元";
        <div class="coupon-card" data-name="@item.CouponName.ToLower()">
            <img src="@item.ImgPath" alt="@item.CouponName">
            <div class="info">
                <h4>@item.CouponName</h4>
                <span>@item.Tag | @showValid</span>
                <p>@showDiscount</p>
                @if (item.IsFree)
                {
                    <div class="free-tag">免费</div>
                }
                else
                {
                    <div>积分：@item.CostPoint</div>
                }
            </div>
            <button class="exchange-btn" data-id="@item.Id">
                @(item.IsFree ? "免费领取" : "兑换优惠券")
            </button>
        </div>
    }
</div>
<div class="footer">
    © 2026 - zhinnegBus - 隐私
</div>
<script>
    const input = document.getElementById("searchInput");
    const cards = document.querySelectorAll(".coupon-card");
    input.addEventListener("input", function () {
        let key = this.value.trim().toLowerCase();
        cards.forEach(card => {
            let name = card.dataset.name;
            card.style.display = name.includes(key) ? "flex" : "none";
        })
    })

    document.querySelectorAll(".exchange-btn").forEach(btn => {
        btn.onclick = async function () {
            let cid = this.dataset.id;
            console.log("前端优惠券ID：", cid);
            let token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            let formData = new FormData();
            formData.append("couponId", cid);
            formData.append("__RequestVerificationToken", token);

            try {
                let res = await fetch(`?handler=Exchange`, {
                    method: "POST",
                    body: formData
                });
                let data = await res.json();
                alert(data.msg);
                if (data.success) location.reload();
            } catch (err) {
                alert("请求出错：" + err);
            }
        }
    })
</script>